# ─────────────────────────────────────────────────────────────────────────────
# AI Business Hub — Environment Variables
# ─────────────────────────────────────────────────────────────────────────────
#
# Copy this file to .env.local and fill in every value before running locally.
# NEVER commit .env.local to git — it contains secrets.
#
# For Vercel deployment: add these in your Vercel project dashboard under
# Settings → Environment Variables. Use the same variable names exactly.
#
# ─────────────────────────────────────────────────────────────────────────────


# ── Authentication ─────────────────────────────────────────────────────────
# The password you'll use to log into the hub.
# Make it something you'll remember but wouldn't guess easily.
# Change it anytime — just update this value and redeploy.
HUB_PASSWORD=your-password-here


# ── Supabase ────────────────────────────────────────────────────────────────
# Get these from your Supabase project dashboard → Settings → API
#
# IMPORTANT: This hub uses TWO different Supabase keys for different purposes.
# The anon key (NEXT_PUBLIC_) is safe to expose in the browser.
# The service role key has full database access — NEVER expose it client-side.

# Your Supabase project URL — looks like https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co

# Anon/public key — safe for browser use
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Service role key — server-side only (API routes, server components, cron)
# Find this in Supabase → Settings → API → service_role key
# WARNING: This key bypasses Row Level Security. Only use in server contexts.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here


# ── Claude / Anthropic ──────────────────────────────────────────────────────
# Get this from console.anthropic.com → API Keys
# All AI agent routes use this key.
# Note: Synthesis and Content Writer use claude-opus-* for quality output.
# Research agents use claude-sonnet-* for speed and cost efficiency.
ANTHROPIC_API_KEY=sk-ant-your-key-here


# ── Research Tools ──────────────────────────────────────────────────────────
# The research agents use Firecrawl for web scraping and Tavily for
# real-time search. Both have usable free tiers — no upfront credits required.

# Firecrawl: firecrawl.dev → Dashboard → API Keys
# Used for: scraping competitor pages, landing pages, blog posts
FIRECRAWL_API_KEY=fc-your-key-here

# Tavily: tavily.com → Dashboard → API Keys
# Used for: real-time web search, trend monitoring, keyword research
# Free tier: 1,000 searches/month — enough to run daily research sweeps
TAVILY_API_KEY=tvly-your-key-here


# ── Optional: Perplexity (Alternative to Tavily) ───────────────────────────
# If you prefer Perplexity over Tavily, set this and uncomment the
# searchWithPerplexity function in lib/research/api-clients.ts.
# Note: Perplexity requires purchasing credits upfront — no free tier.
# PERPLEXITY_API_KEY=pplx-your-key-here


# ── Cron Security ───────────────────────────────────────────────────────────
# A random secret string that authenticates Vercel cron job requests.
# The cron route checks: Authorization: Bearer YOUR_CRON_SECRET
# Generate a random string — any password generator works.
# Example: openssl rand -hex 32
CRON_SECRET=your-random-cron-secret-here


# ── Optional: AuthoredUp ────────────────────────────────────────────────────
# Required only if you're using the AuthoredUp integration (your own LinkedIn
# post performance + saved/competitor post tracking).
# Get from: platform.authoredup.com/account/user → "Generate key"
# Requires a valid AuthoredUp license (trial or paid).
AUTHOREDUP_API_KEY=


# ── Optional: YouTube ──────────────────────────────────────────────────────
# Required only if you're using the YouTube research agent.
# Get from: console.cloud.google.com → APIs & Services → Credentials
# Enable the YouTube Data API v3 in your Google Cloud project first.
YOUTUBE_API_KEY=

# Your YouTube channel ID (not the @handle — the UCxxxxxxxxx string)
# Find it at youtube.com/account_advanced or by searching "my youtube channel id"
YOUTUBE_CHANNEL_ID=


# ── Optional: Financial Tracking ───────────────────────────────────────────
# Required only if you're using the Revenue/Financial pages.
# Get from: dashboard.stripe.com → Developers → API Keys
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=


# ── Optional: Email Marketing ──────────────────────────────────────────────
# Required only if you're connecting an email platform.
# Remove or ignore whichever platform you don't use.

# Bento (bentonow.com)
BENTO_SITE_UUID=
BENTO_PUBLISHABLE_KEY=
BENTO_SECRET_KEY=

# Kit / ConvertKit
CONVERTKIT_API_KEY=
CONVERTKIT_API_SECRET=

# Mailchimp
MAILCHIMP_API_KEY=
MAILCHIMP_SERVER_PREFIX=


# ── Optional: Social Publishing ────────────────────────────────────────────
# Required only if you're using the Distribution layer to publish automatically.

# LinkedIn (OAuth2)
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_ACCESS_TOKEN=
LINKEDIN_MEMBER_ID=


# ── Optional: Google OAuth ─────────────────────────────────────────────────
# Required only if you want Google sign-in instead of password auth.
# Get from: console.cloud.google.com → OAuth 2.0 Client IDs
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=


# ── Next.js ─────────────────────────────────────────────────────────────────
# Set automatically by Vercel. Only needed locally if you're testing
# absolute URL generation (the research orchestrator uses this).
# Leave blank locally — the app falls back to localhost.
NEXT_PUBLIC_APP_URL=
